# EAS project ID (@youjh824/artlog) — slug는 app.config.js에서 artlog 로 고정
EAS_PROJECT_ID=4b3ec554-e483-498e-b221-03f918005550
# EAS_PROJECT_SLUG=artlog

# Production 빌드용 HTTPS 웹 URL
# EXPO_PUBLIC_WEB_APP_URL=https://artlog.yourdomain.com

# Android FCM (원격 푸시, 선택)
# GOOGLE_SERVICES_JSON=./google-services.json

# OpenAI API (앱 WebView에서 AI 피드백 생성)
EXPO_PUBLIC_OPENAI_API_KEY=sk-your-openai-api-key

# Supabase (embedded-web 빌드 + 런타임)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ-your-anon-key

# ── APK 빌드 시 중요 ──
# Expo(로컬)는 이 .env를 자동으로 읽지만, EAS 클라우드 빌드는 .env 파일을 업로드하지 않습니다 (.easignore).
# npm run mobile:build:preview 실행 시 build 스크립트가 EAS preview 환경에 키를 자동 동기화합니다.
# 수동 등록: npx eas-cli env:create --name EXPO_PUBLIC_OPENAI_API_KEY --value "sk-..." --environment preview --visibility sensitive --force
