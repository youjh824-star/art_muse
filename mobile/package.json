{
  "name": "artlog-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:tunnel": "expo start --tunnel",
    "start:lan": "expo start --lan --clear --port 8081",
    "start:dev": "expo start --lan --clear --port 8081",
    "start:dev:win": "scripts\\start-dev.cmd",
    "android:usb": "scripts\\connect-android.cmd",
    "usb": "scripts\\connect-android.cmd",
    "dev:metro": "scripts\\start-metro.cmd",
    "metro": "scripts\\start-metro.cmd",
    "android:emu": "scripts\\start-emulator.cmd",
    "android:env": "scripts\\check-android-env.cmd",
    "android:env:setup": "scripts\\setup-android-env.cmd",
    "build:local:android": "scripts\\local-build-android.cmd admin",
    "build:local:android:admin": "scripts\\local-build-android.cmd admin",
    "build:local:android:admin:v2": "scripts\\local-build-android.cmd admin v2",
    "build:local:android:parent:v2": "scripts\\local-build-android.cmd parent v2",
    "build:local:android:parent": "scripts\\local-build-android.cmd parent",
    "firewall": "scripts\\open-firewall.cmd",
    "reset": "scripts\\reset-cache.cmd",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "bundle:web": "node scripts/bundle-web.mjs admin",
    "bundle:web:admin": "node scripts/bundle-web.mjs admin",
    "bundle:web:parent": "node scripts/bundle-web.mjs parent",
    "bundle:web:admin:v2": "node scripts/bundle-web.mjs admin v2",
    "bundle:web:parent:v2": "node scripts/bundle-web.mjs parent v2",
    "build:preview": "npm run bundle:web:admin && node scripts/eas-build-preview.mjs admin",
    "build:preview:admin": "npm run bundle:web:admin && node scripts/eas-build-preview.mjs admin",
    "build:preview:parent": "npm run bundle:web:parent && node scripts/eas-build-preview.mjs parent",
    "build:preview:admin:ios": "npm run bundle:web:admin && node scripts/eas-build-preview.mjs admin ios",
    "build:preview:parent:ios": "npm run bundle:web:parent && node scripts/eas-build-preview.mjs parent ios",
    "build:production:admin": "npm run bundle:web:admin && npx eas-cli build --profile production-admin --platform all --non-interactive",
    "build:production:parent": "npm run bundle:web:parent && npx eas-cli build --profile production-parent --platform all --non-interactive",
    "build:preview:ios": "npx eas-cli build --profile production --platform ios",
    "build:production": "npx eas-cli build --profile production --platform all",
    "build:production:android": "npx eas-cli build --profile production --platform android",
    "eas:init": "npx eas-cli init",
    "eas:login": "npx eas-cli login",
    "submit:ios": "npx eas-cli submit --platform ios --latest",
    "submit:android": "npx eas-cli submit --platform android --latest",
    "assets": "node scripts/generate-assets.mjs",
    "app-icon": "node scripts/set-app-icon.mjs ./assets/icon-source.png"
  },
  "dependencies": {
    "expo": "~54.0.0",
    "expo-asset": "~12.0.13",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.22",
    "expo-image-picker": "~17.0.11",
    "expo-notifications": "~0.32.17",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "babel-preset-expo": "~54.0.0",
    "sharp": "^0.34.5"
  }
}
