    "mobile:build:preview:parent": "cd mobile && npm run build:preview:parent",
    "mobile:build:preview:admin:ios": "cd mobile && npm run build:preview:admin:ios",
    "mobile:build:preview:parent:ios": "cd mobile && npm run build:preview:parent:ios",
    "mobile:build:production:admin": "cd mobile && npm run build:production:admin",
    "mobile:build:production:parent": "cd mobile && npm run build:production:parent",
