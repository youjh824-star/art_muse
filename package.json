    "mobile:metro": "cd mobile && npm run dev:metro",
    "mobile:emu": "cd mobile && npm run android:emu",
    "mobile:tunnel": "cd mobile && npm run start:tunnel",
    "mobile:install": "cd mobile && npm install",
